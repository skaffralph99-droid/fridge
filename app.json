{
  "expo": {
    "name": "Fridge Manager",
    "slug": "fridge-manager",
    "version": "1.0.0",
    "scheme": "fridge",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": { "backgroundColor": "#0A1628" },
    "ios": { "bundleIdentifier": "com.fridge.manager", "supportsTablet": false },
    "android": { "package": "com.fridge.manager", "adaptiveIcon": { "foregroundImage": "./assets/images/icon.png", "backgroundColor": "#0A1628" } },
    "plugins": ["expo-router", "expo-font", "expo-web-browser"],
    "experiments": { "typedRoutes": true }
  }
}
